# ~/.devid/identity.toml
# devid v1 schema
# Keep values terse. Full sentences cost tokens. Fragments are fine.

[meta]
version = "1"
updated_at = 2026-04-06T00:00:00Z

# --- IDENTITY ----------------------------------------------------------------
# ~50-80 tokens. Always loaded.

[identity]
name = "Nathan"
tone = "direct, plain-spoken, no fluff, no emoji, northern"
comments = "sound like the dev wrote it, not a textbook"
responses = "prose over bullets unless explicitly needed, hyphens not em dashes"
pace = "move fast, minimal hand-holding, skip obvious explanations"

# --- STACK --------------------------------------------------------------------
# ~60-100 tokens. Always loaded.

[stack]
primary   = ["Go", "TypeScript", "Next.js"]
secondary = ["C#", ".NET"]
data      = ["PostgreSQL", "Supabase"]
infra     = ["Tailscale", "PM2", "Vercel", "GitHub Actions", "Docker"]
messaging = ["Kafka", "Flink"]
cloud     = ["GCP", "AWS"]
testing   = ["Jest", "Go testing stdlib"]

[stack.avoid]
items = ["playwright-go", "Prisma", "ORM abstraction over raw SQL"]

[stack.avoid.reasons]
playwright_go = "community wrapper, lags behind, use JS/TS for Playwright"

# --- CONVENTIONS --------------------------------------------------------------
# ~40-70 tokens. Always loaded.

[conventions]
formatting     = "hyphens not em dashes, no trailing punctuation in comments"
pr_style       = "small focused PRs, one concern per PR"
commit_style   = "conventional commits, lowercase, imperative mood"
error_handling = "explicit, no silent swallows, log with context"
naming         = "clear over clever, full words not abbreviations"

# --- PROJECTS -----------------------------------------------------------------
# Loaded on demand by project name match. ~30-50 tokens per project.

[[projects]]
name    = "coentry"
repo    = "coentry"
stack   = ["Next.js", "TypeScript", "Supabase", "Playwright", "PM2"]
infra   = ["ThinkCentre M920q", "Tailscale", "Vercel", "GitHub Actions"]
context = "B2B healthcare CRM and outreach platform. NHS prospect database. Email blast daemon via Playwright. AI email classification."
patterns = [
  "blast-daemon.js managed by PM2",
  "Go for orchestration, JS/TS for Playwright layer",
  "Supabase auth restricted to coentry.co.uk domain",
]

[[projects]]
name    = "bet365-work"
repo    = "bet365"
stack   = ["Go", "Kafka", "Flink", "BigQuery", "GCP"]
context = "High-scale betting platform. Event-driven architecture. Do not suggest rewrites or framework changes."
patterns = [
  "vanilla patterns preferred over frameworks",
  "performance and reliability over developer convenience",
]

# --- AI TOOL PREFERENCES -----------------------------------------------------
# ~20-40 tokens. Always loaded.

[ai]
verbosity    = "concise, skip preamble, get to the point"
confirmation = "don't ask permission for obvious next steps, just do it"
suggestions  = "challenge assumptions, search before agreeing, flag better alternatives"
code_comments = "minimal, only non-obvious logic"
tests        = "write them, don't ask if I want them"

# --- LEARNED ------------------------------------------------------------------
# Written by devid sync. Human-readable record of inferred preferences.
# ~variable. Reviewed before writing, trimmed regularly.

[learned]
entries = [
  "2026-04-06: prefers explicit error types in Go over generic error wrapping",
]

# --- PRIVATE ------------------------------------------------------------------
# Excluded from all distribution targets. Never rendered into output files.

[private]
api_key = "example-secret-that-should-never-appear-in-output"
